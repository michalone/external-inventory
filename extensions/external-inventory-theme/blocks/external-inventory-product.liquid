{% if product %}
  <div
    class="external-inventory-lead-time"
    data-external-inventory-lead-time
    data-endpoint="/apps/external-inventory"
    data-locale="{{ localization.language.iso_code | default: shop.locale }}"
  >
    <p data-product-id="{{ product.id }}" data-external-inventory-message hidden></p>
  </div>

  <script src="{{ 'external-inventory-lead-time.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% schema %}
{
  "name": "External Lead Time (Prod)",
  "target": "section",
  "templates": ["product"],
  "settings": []
}
{% endschema %}
